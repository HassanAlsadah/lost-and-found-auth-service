# ============================================
# Factor 3: Configuration
# All config is stored in environment variables
# NEVER hardcode these values in code
# ============================================

# Server
PORT=3001
NODE_ENV=development

# Database (Factor 4: Backing Service)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lostandfound
DB_USER=postgres
DB_PASSWORD=changeme

# Redis Cache (Factor 4: Backing Service)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# Logging (Factor 11: Logs to stdout)
LOG_LEVEL=info
